{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Taurvia",
  "version": "0.4.3",
  "identifier": "com.taurvia.wallet",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Taurvia",
        "width": 1100,
        "height": 720,
        "minWidth": 420,
        "minHeight": 560,
        "backgroundColor": "#0b0f14"
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' asset:",
        "connect-src": "ipc: http://ipc.localhost",
        "img-src": "'self' asset: data: https:",
        "style-src": "'unsafe-inline' 'self'"
      },
      "devCsp": "default-src 'self' asset: ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1421; connect-src 'self' ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1421; img-src 'self' asset: data: https:; style-src 'unsafe-inline' 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Finance",
    "shortDescription": "Non-custodial Solana desktop wallet",
    "longDescription": "Taurvia is a non-custodial Solana wallet. Keys stay encrypted on your device.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false,
        "files": {}
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
