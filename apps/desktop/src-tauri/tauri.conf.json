{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aegis",
  "version": "0.1.2",
  "identifier": "com.aegis.wallet",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aegis",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "backgroundColor": "#0b0f14"
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' asset:",
        "connect-src": "ipc: http://ipc.localhost",
        "img-src": "'self' asset: data:",
        "style-src": "'unsafe-inline' 'self'"
      },
      "devCsp": "default-src 'self' asset: ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1421; connect-src 'self' ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1421; img-src 'self' asset: data:; style-src 'unsafe-inline' 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false,
        "files": {}
      }
    }
  }
}
