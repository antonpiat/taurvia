# Optional Solana RPC endpoint (Helius, QuickNode, or public RPC)
# TAURVIA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Default fallback if unset:
# https://api.mainnet-beta.solana.com

# Optional Jupiter API key (free tier at https://portal.jup.ag)
# Keyless requests work by default; set this for higher rate limits.
# TAURVIA_JUPITER_API_KEY=
